---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const recipes = await getCollection("recipes");
  return recipes.map((recipe) => {
    const slug = recipe.id.replace(/\.mdx?$/, "");
    return {
      params: { id: slug },
      props: { recipe },
    };
  });
}

const { recipe } = Astro.props;
const { Content } = await recipe.render();

// Group ingredients by category
const groupedIngredients = recipe.data.ingredients.reduce(
  (acc, ingredient) => {
    const category = ingredient.category || "Principal";
    if (!acc[category]) {
      acc[category] = [];
    }
    acc[category].push(ingredient);
    return acc;
  },
  {} as Record<string, typeof recipe.data.ingredients>,
);
---

<BaseLayout title={`Kitchen OS | ${recipe.data.title}`}>
  <div class="mb-8">
    <a
      href="/"
      class="font-mono text-sm opacity-80 hover:text-[var(--color-accent)] hover:opacity-100 transition-colors"
    >
      ← RETOUR À L'ACCUEIL
    </a>
  </div>

  <article class="surface-card p-6 md:p-8">
    <header class="mb-8 border-b border-[var(--color-border-grid)] pb-6">
      {
        recipe.data.cover && (
          <div class="w-full h-64 md:h-96 mb-8 border border-[var(--color-border-grid)] p-2 relative group overflow-hidden">
            {/* HUD Overlay */}
            <div class="absolute inset-2 pointer-events-none z-10 border border-[var(--color-accent)] opacity-20 group-hover:opacity-40 transition-opacity">
              <div class="absolute top-0 left-1/2 w-[1px] h-4 bg-[var(--color-accent)] -translate-x-1/2" />
              <div class="absolute bottom-0 left-1/2 w-[1px] h-4 bg-[var(--color-accent)] -translate-x-1/2" />
              <div class="absolute top-1/2 left-0 w-4 h-[1px] bg-[var(--color-accent)] -translate-y-1/2" />
              <div class="absolute top-1/2 right-0 w-4 h-[1px] bg-[var(--color-accent)] -translate-y-1/2" />
              <div class="absolute inset-0 bg-[linear-gradient(rgba(0,209,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,209,255,0.03)_1px,transparent_1px)] bg-[size:20px_20px]" />
            </div>
            <Image
              src={recipe.data.cover}
              alt={recipe.data.title}
              class="w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 relative z-0"
            />
          </div>
        )
      }
      <div class="flex items-center gap-3 mb-4">
        <span
          class="bg-[var(--color-accent)] text-white px-2 py-1 text-xs font-bold w-fit"
        >
          PROTOCOLE
        </span>
        <h1 class="text-3xl m-0">{recipe.data.title}</h1>
      </div>
      <p class="font-mono text-sm opacity-80">{recipe.data.description}</p>

      <div class="mt-6 font-mono text-sm flex gap-6">
        <div
          class="flex flex-col border-l-4 border-l-[var(--color-accent)] border-y border-r border-[var(--color-border-grid)] bg-[var(--color-surface)] p-3 min-w-[120px] relative"
        >
          <div
            class="absolute top-0 right-0 w-2 h-2 border-b border-l border-[var(--color-border-grid)]"
          >
          </div>
          <span
            class="text-[var(--color-accent)] font-bold mb-1 opacity-80 text-xs glow-accent"
          >
            PORTIONS
          </span>
          <span class="text-2xl mt-1 font-dot">{recipe.data.baseServings}</span>
        </div>

        {
          recipe.data.kcal && (
            <div class="flex flex-col border-l-4 border-l-[var(--color-accent)] border-y border-r border-[var(--color-border-grid)] bg-[var(--color-surface)] p-3 min-w-[120px] relative">
              <div class="absolute top-0 right-0 w-2 h-2 border-b border-l border-[var(--color-border-grid)]" />
              <span class="text-[var(--color-accent)] font-bold mb-1 opacity-80 text-xs glow-accent">
                KCAL/PORTION
              </span>
              <span class="text-2xl mt-1 font-dot">{recipe.data.kcal}</span>
            </div>
          )
        }
      </div>
    </header>

    <div class="grid md:grid-cols-3 gap-8">
      <div class="md:col-span-1">
        <div class="surface-card px-4 border-0 h-full">
          <h3
            class="font-dot text-[var(--color-accent)] border-b border-[var(--color-border-grid)] pb-2 mb-4 mt-0 text-xl tracking-wider"
          >
            INGRÉDIENTS
          </h3>
          {
            Object.entries(groupedIngredients).map(([category, items]) => (
              <div class="mb-6 last:mb-0">
                {category !== "Principal" && (
                  <h4 class="font-dot text-sm text-[var(--color-accent)] opacity-80 mb-2 mt-0 tracking-wider">
                    [{category.toUpperCase()}]
                  </h4>
                )}
                <ul class="font-mono text-sm flex flex-col gap-3 m-0 list-none ingredient-list">
                  {items.map((ing) => (
                    <li class="flex justify-between items-start border-b border-[var(--color-border-grid)] border-opacity-50 pb-2 group hover:bg-[var(--color-border-grid)] hover:bg-opacity-20 transition-all px-2 -mx-2 cursor-pointer select-none">
                      <div class="flex gap-1 items-start">
                        <span class="text-[var(--color-accent)] opacity-50 group-hover:opacity-100 transition-opacity shrink-0 font-bold w-7 whitespace-nowrap check-box">
                          [ ]
                        </span>
                        <span class="ingredient-name transition-colors">
                          {ing.name}
                        </span>
                      </div>
                      <span class="font-bold text-xs text-right shrink-0 text-[var(--color-accent)] opacity-80 group-hover:opacity-100 transition-opacity mt-[2px] ml-2">
                        {ing.quantity ? `${ing.quantity} ` : ""}
                        {ing.unit}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>

      <div class="md:col-span-2 text-[#1A202C]">
        <h3
          class="font-dot text-[var(--color-accent)] border-b border-[var(--color-border-grid)] pb-2 mb-4 mt-0 text-xl tracking-wider"
        >
          PLAN D'EXÉCUTION
        </h3>
        <div class="recipe-content leading-relaxed">
          <Content />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  @reference "../../styles/global.css";

  .recipe-content h1,
  .recipe-content h2,
  .recipe-content h3 {
    @apply font-dot text-[var(--color-accent)] mt-6 mb-3 uppercase text-2xl tracking-wide;
  }

  .recipe-content p {
    @apply mb-4 text-[#1A202C] opacity-90;
  }

  .recipe-content strong {
    @apply text-[var(--color-alert)];
  }

  /* Interactive States for Ingredients */
  .checked {
    @apply opacity-75;
  }
  .checked .ingredient-name {
    @apply line-through text-[#718096];
  }
</style>

<script>
  // Setup interactivity for ingredient list
  const setupIngredients = () => {
    const listItems = document.querySelectorAll(".ingredient-list li");

    listItems.forEach((item) => {
      // Remove old listeners to prevent duplicates on navigation
      const newEl = item.cloneNode(true) as Element;
      if (item.parentNode) {
        item.parentNode.replaceChild(newEl, item);
      }

      newEl.addEventListener("click", () => {
        newEl.classList.toggle("checked");
        const checkBox = newEl.querySelector(".check-box");
        if (checkBox) {
          if (newEl.classList.contains("checked")) {
            checkBox.textContent = "[X]";
            checkBox.classList.replace(
              "text-[var(--color-accent)]",
              "text-[#718096]",
            );
          } else {
            checkBox.textContent = "[ ]";
            checkBox.classList.replace(
              "text-[#718096]",
              "text-[var(--color-accent)]",
            );
          }
        }
      });
    });
  };

  // Run on first load
  setupIngredients();

  // Run on Astro page navigation
  document.addEventListener("astro:page-load", setupIngredients);
</script>
