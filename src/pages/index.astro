---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const recipes = await getCollection("recipes");
const allTags = [
  "tous",
  ...new Set(recipes.flatMap((r) => r.data.tags.map((t) => t.toLowerCase()))),
].sort((a, b) => (a === "tous" ? -1 : b === "tous" ? 1 : a.localeCompare(b)));
---

<BaseLayout title="Antoine's Kitchen | Accueil" fullWidth={true}>
  <div class="os-header mb-8">
    <div>
      <h1 class="os-title">
        /antoinepoups_kitchen<span class="cursor-blink"></span>
      </h1>
      <p class="os-subtitle">Mes recettes testées et approuvées...</p>
    </div>
  </div>

  <section>
    <div
      class="flex flex-col md:flex-row md:items-center justify-between mb-6 gap-4"
    >
      <h2 class="section-heading text-2xl glow-accent m-0">
        RECETTES DISPONIBLES
      </h2>
      <div
        class="flex gap-2 overflow-x-auto pb-2 md:pb-0 scrollbar-hide category-filters select-none"
      >
        {
          allTags.map((tag) => (
            <button
              class={`filter-btn px-3 py-1 text-sm font-mono border border-[var(--color-border-grid)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors whitespace-nowrap ${tag === "tous" ? "active bg-[var(--color-accent)] text-white hover:text-white" : "text-[#1A202C] opacity-80"}`}
              data-filter={tag}
            >
              [{tag.toUpperCase()}]
            </button>
          ))
        }
      </div>
    </div>
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 recipe-grid"
    >
      {
        recipes.map((recipe) => {
          const slug = recipe.id.replace(/\.mdx?$/, "");
          const tagsJson = JSON.stringify(
            recipe.data.tags.map((t) => t.toLowerCase()),
          );
          return (
            <a
              href={`/recipes/${slug}`}
              class="recipe-card group"
              data-tags={tagsJson}
            >
              {/* Corner Stroke */}
              <svg
                class="absolute bottom-[-1px] right-[-1px] w-[16px] h-[16px] pointer-events-none z-20"
                viewBox="0 0 16 16"
              >
                <line
                  x1="16"
                  y1="0"
                  x2="0"
                  y2="16"
                  stroke="var(--color-border-grid)"
                  stroke-width="1.5"
                  class="group-hover:stroke-[var(--color-accent)] transition-colors duration-300"
                />
              </svg>

              {/* Decorative Brackets */}
              <div class="card-bracket top-2 left-2 border-t-2 border-l-2" />
              <div class="card-bracket top-2 right-2 border-t-2 border-r-2" />
              <div class="card-bracket bottom-2 left-2 border-b-2 border-l-2" />

              {/* Cover image with tag overlay */}
              <div class="relative h-48 w-full border-b border-[var(--color-border-grid)] overflow-hidden">
                {recipe.data.cover && (
                  <Image
                    src={recipe.data.cover}
                    alt={recipe.data.title}
                    class="w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500"
                  />
                )}
                {/* Tags overlaid top-left */}
                <div class="absolute top-2 left-2 z-10 flex flex-wrap gap-1">
                  {recipe.data.tags.map((tag) => (
                    <span class="recipe-tag bg-black/50 text-white backdrop-blur-sm text-xs px-2 py-0.5">
                      [{tag.toUpperCase()}]
                    </span>
                  ))}
                </div>
              </div>

              <div class="p-6 flex flex-col flex-grow justify-between">
                <div>
                  <div class="flex items-center justify-end mb-3">
                    <span class="font-mono text-xs opacity-60 flex gap-3">
                      {recipe.data.kcal && <span>{recipe.data.kcal} KCAL</span>}
                      <span>{recipe.data.baseServings} PORTIONS</span>
                    </span>
                  </div>
                  <h3 class="text-xl m-0 mb-2 group-hover:text-[var(--color-accent)] transition-colors">
                    {recipe.data.title}
                  </h3>
                  <p class="font-mono text-sm opacity-70 m-0 line-clamp-2">
                    {recipe.data.description}
                  </p>
                </div>

                <div class="mt-6 flex justify-between items-center font-mono text-sm border-t border-[var(--color-border-grid)] pt-3 border-opacity-50">
                  <div class="flex gap-4">
                    <span>P:{recipe.data.difficulty.prep}</span>
                    <span>T:{recipe.data.difficulty.technique}</span>
                    <span>N:{recipe.data.difficulty.cleanup}</span>
                  </div>
                  <span class="btn-execute">VOIR LA RECETTE</span>
                </div>
              </div>
            </a>
          );
        })
      }
    </div>
  </section>
</BaseLayout>

<script>
  // Setup Category Filters
  const setupFilters = () => {
    const filterBtns = document.querySelectorAll(".filter-btn");
    const recipeCards = document.querySelectorAll<HTMLElement>(".recipe-card");

    filterBtns.forEach((btn) => {
      const newBtn = btn.cloneNode(true) as HTMLButtonElement;
      if (btn.parentNode) btn.parentNode.replaceChild(newBtn, btn);

      newBtn.addEventListener("click", () => {
        const filterStr = newBtn.dataset.filter;

        // Update active class on all buttons
        document.querySelectorAll(".filter-btn").forEach((b) => {
          b.classList.remove(
            "bg-[var(--color-accent)]",
            "text-white",
            "active",
          );
          b.classList.add("text-[#1A202C]", "opacity-80");
        });
        newBtn.classList.remove("text-[#1A202C]", "opacity-80");
        newBtn.classList.add(
          "bg-[var(--color-accent)]",
          "text-white",
          "active",
        );

        // Filter cards based on tags array
        recipeCards.forEach((card) => {
          if (filterStr === "tous") {
            card.style.display = "block";
          } else {
            const cardTags: string[] = JSON.parse(card.dataset.tags || "[]");
            card.style.display = cardTags.includes(filterStr!)
              ? "block"
              : "none";
          }
        });
      });
    });
  };

  setupFilters();
  document.addEventListener("astro:page-load", setupFilters);
</script>
