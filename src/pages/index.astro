---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const recipes = await getCollection("recipes");
const allTags = [
  "tous",
  ...new Set(recipes.flatMap((r) => r.data.tags.map((t) => t.toLowerCase()))),
].sort((a, b) => (a === "tous" ? -1 : b === "tous" ? 1 : a.localeCompare(b)));
---

<BaseLayout title="Antoine's Kitchen | Accueil" fullWidth={true}>
  <div class="os-header mb-8">
    <div>
      <!-- Portfolio Pill -->
      <div class="mb-8 flex">
        <a
          href="https://www.pantoine.com"
          target="_blank"
          rel="noopener noreferrer"
          class="relative flex flex-nowrap items-center justify-center gap-3 px-3 py-2 border border-[var(--color-border-grid)] hover:border-[var(--color-accent)] rounded-full font-mono text-sm group transition-all duration-300 ease-in-out bg-white"
        >
          <div class="flex items-center gap-2">
            <svg
              width="14"
              height="14"
              viewBox="12.7 17.8 37 37"
              xmlns="http://www.w3.org/2000/svg"
              class="text-[var(--color-accent)]"
              fill="currentColor"
            >
              <path
                d="M 31.2344 54.7305 C 31.8438 54.7305 32.2891 54.2852 32.4062 53.6524 C 34.0703 40.8086 35.8750 38.8633 48.5781 37.4570 C 49.2344 37.3867 49.6797 36.8945 49.6797 36.2852 C 49.6797 35.6758 49.2344 35.2070 48.5781 35.1133 C 35.8750 33.7070 34.0703 31.7617 32.4062 18.9180 C 32.2891 18.2852 31.8438 17.8633 31.2344 17.8633 C 30.6250 17.8633 30.1797 18.2852 30.0860 18.9180 C 28.4219 31.7617 26.5938 33.7070 13.9140 35.1133 C 13.2344 35.2070 12.7891 35.6758 12.7891 36.2852 C 12.7891 36.8945 13.2344 37.3867 13.9140 37.4570 C 26.5703 39.1211 28.3281 40.8321 30.0860 53.6524 C 30.1797 54.2852 30.6250 54.7305 31.2344 54.7305 Z"
              ></path>
            </svg>
            <span
              class="whitespace-nowrap opacity-80 group-hover:opacity-100 transition-opacity"
              >Visitez mon portfolio</span
            >
          </div>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            class="size-4 stroke-2 fill-none stroke-current group-hover:stroke-[var(--color-accent)] transition-colors duration-300"
          >
            <line
              x1="5"
              y1="12"
              x2="19"
              y2="12"
              class="translate-x-3 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out"
            ></line>
            <polyline
              points="12 5 19 12 12 19"
              class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out"
            ></polyline>
          </svg>
        </a>
      </div>
      <h1 class="os-title">
        /antoines_kitchen<span class="cursor-blink"></span>
      </h1>
      <p class="os-subtitle">Mes recettes testées et approuvées...</p>
    </div>
  </div>

  <section>
    <div
      class="flex flex-col md:flex-row md:items-center justify-between mb-6 gap-4"
    >
      <h2 class="section-heading text-2xl glow-accent m-0">
        RECETTES DISPONIBLES
      </h2>
      <div
        class="flex gap-2 overflow-x-auto pb-2 md:pb-0 scrollbar-hide category-filters select-none"
      >
        {
          allTags.map((tag) => (
            <button
              class={`filter-btn px-3 py-1 text-sm font-mono border border-[var(--color-border-grid)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors whitespace-nowrap ${tag === "tous" ? "active bg-[var(--color-accent)] text-white" : "text-[#1A202C] opacity-80"}`}
              data-filter={tag}
            >
              [{tag.toUpperCase()}]
            </button>
          ))
        }
      </div>
    </div>
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 recipe-grid"
    >
      {
        recipes.map((recipe) => {
          const slug = recipe.id.replace(/\.mdx?$/, "");
          const tagsJson = JSON.stringify(
            recipe.data.tags.map((t) => t.toLowerCase()),
          );
          return (
            <a
              href={`/recipes/${slug}`}
              class="recipe-card group"
              data-tags={tagsJson}
            >
              {/* Corner Stroke */}
              <svg
                class="absolute bottom-[-1px] right-[-1px] w-[16px] h-[16px] pointer-events-none z-20"
                viewBox="0 0 16 16"
              >
                <line
                  x1="16"
                  y1="0"
                  x2="0"
                  y2="16"
                  stroke="var(--color-border-grid)"
                  stroke-width="1.5"
                  class="group-hover:stroke-[var(--color-accent)] transition-colors duration-300"
                />
              </svg>

              {/* Decorative Brackets */}
              <div class="card-bracket top-2 left-2 border-t-2 border-l-2" />
              <div class="card-bracket top-2 right-2 border-t-2 border-r-2" />
              <div class="card-bracket bottom-2 left-2 border-b-2 border-l-2" />

              {/* Cover image with tag overlay */}
              <div class="relative h-48 w-full border-b border-[var(--color-border-grid)] overflow-hidden">
                {recipe.data.cover && (
                  <Image
                    src={recipe.data.cover}
                    alt={recipe.data.title}
                    class="w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500"
                  />
                )}
                {/* Light blue overlay — fades on hover */}
                <div class="absolute inset-0 z-10 bg-[var(--color-accent)]/10 group-hover:opacity-0 transition-opacity duration-500 pointer-events-none" />
                {/* Tags overlaid top-left */}
                <div class="absolute top-2 left-2 z-20 flex flex-wrap gap-1">
                  {recipe.data.tags.map((tag) => (
                    <span class="recipe-tag bg-black/50 text-white backdrop-blur-sm text-xs px-2 py-0.5">
                      [{tag.toUpperCase()}]
                    </span>
                  ))}
                </div>
              </div>

              <div class="p-6 flex flex-col flex-grow justify-between">
                <div>
                  <div class="flex items-center justify-start mb-3">
                    <span class="font-mono text-xs opacity-60 flex gap-3">
                      {recipe.data.kcal && <span>{recipe.data.kcal} KCAL</span>}
                      <span>{recipe.data.baseServings} PORTIONS</span>
                    </span>
                  </div>
                  <h3 class="text-xl m-0 mb-2 group-hover:text-[var(--color-accent)] transition-colors">
                    {recipe.data.title}
                  </h3>
                  <p class="font-mono text-sm opacity-70 m-0 line-clamp-2">
                    {recipe.data.description}
                  </p>
                </div>

                <div class="mt-6 flex justify-between items-center font-mono text-sm border-t border-[var(--color-border-grid)] pt-3 border-opacity-50">
                  <div class="flex gap-4">
                    <span>{recipe.data.ingredients.length} INGRÉDIENTS</span>
                  </div>
                  <span class="btn-execute">VOIR LA RECETTE</span>
                </div>
              </div>
            </a>
          );
        })
      }
    </div>
  </section>
</BaseLayout>

<script>
  // Setup Category Filters
  const setupFilters = () => {
    const filterBtns = document.querySelectorAll(".filter-btn");
    const recipeCards = document.querySelectorAll<HTMLElement>(".recipe-card");

    filterBtns.forEach((btn) => {
      const newBtn = btn.cloneNode(true) as HTMLButtonElement;
      if (btn.parentNode) btn.parentNode.replaceChild(newBtn, btn);

      newBtn.addEventListener("click", () => {
        const filterStr = newBtn.dataset.filter;

        // Update active class on all buttons
        document.querySelectorAll(".filter-btn").forEach((b) => {
          b.classList.remove(
            "bg-[var(--color-accent)]",
            "text-white",
            "active",
          );
          b.classList.add("text-[#1A202C]", "opacity-80");
        });
        newBtn.classList.remove("text-[#1A202C]", "opacity-80");
        newBtn.classList.add(
          "bg-[var(--color-accent)]",
          "text-white",
          "active",
        );

        // Filter cards based on tags array
        recipeCards.forEach((card) => {
          if (filterStr === "tous") {
            card.style.display = "block";
          } else {
            const cardTags: string[] = JSON.parse(card.dataset.tags || "[]");
            card.style.display = cardTags.includes(filterStr!)
              ? "block"
              : "none";
          }
        });
      });
    });
  };

  setupFilters();
  document.addEventListener("astro:page-load", setupFilters);
</script>

<style>
  /* Keep active filter button text white (not blue-on-blue) on hover */
  .filter-btn.active:hover {
    color: white !important;
  }
</style>
