---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const recipes = await getCollection("recipes");
---

<BaseLayout title="Kitchen OS | Main">
  <div class="os-header">
    <div>
      <h1 class="os-title">
        /antoinepoups_kitchen<span class="cursor-blink"></span>
      </h1>
      <p class="os-subtitle">
        Mes recettes testées et approuvées...
      </p>
    </div>
    <div class="os-system-status">
      <span
        >SYSTEM STATUS: <span class="text-[var(--color-accent)] glow-accent"
          >SECURE</span
        ></span
      >
      <span>UPTIME: <span id="uptime-counter">00:00:00</span></span>
    </div>
  </div>

  <section>
    <h2 class="section-heading mb-6 text-2xl glow-accent">
      PROTOCOLES DISPONIBLES
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        recipes.map((recipe) => {
          const slug = recipe.id.replace(/\.mdx?$/, "");
          return (
            <a href={`/recipes/${slug}`} class="recipe-card group">
              {/* Corner Stroke */}
              <svg
                class="absolute bottom-[-1px] right-[-1px] w-[16px] h-[16px] pointer-events-none z-20"
                viewBox="0 0 16 16"
              >
                <line
                  x1="16"
                  y1="0"
                  x2="0"
                  y2="16"
                  stroke="var(--color-border-grid)"
                  stroke-width="1.5"
                  class="group-hover:stroke-[var(--color-accent)] transition-colors duration-300"
                />
              </svg>

              {/* Decorative Brackets */}
              <div class="card-bracket top-2 left-2 border-t-2 border-l-2" />
              <div class="card-bracket top-2 right-2 border-t-2 border-r-2" />
              <div class="card-bracket bottom-2 left-2 border-b-2 border-l-2" />
              {recipe.data.cover && (
                <div class="h-48 w-full border-b border-[var(--color-border-grid)] overflow-hidden">
                  <Image
                    src={recipe.data.cover}
                    alt={recipe.data.title}
                    class="w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500"
                  />
                </div>
              )}
              <div class="p-6 flex flex-col flex-grow justify-between">
                <div>
                  <div class="flex items-center justify-between mb-3">
                    <span class="recipe-tag">
                      [{recipe.data.category.toUpperCase()}]
                    </span>
                    <span class="font-mono text-xs opacity-60 flex gap-3">
                      {recipe.data.kcal && <span>{recipe.data.kcal} KCAL</span>}
                      <span>{recipe.data.baseServings} PORTIONS</span>
                    </span>
                  </div>
                  <h3 class="text-xl m-0 mb-2 group-hover:text-[var(--color-accent)] transition-colors">
                    {recipe.data.title}
                  </h3>
                  <p class="font-mono text-sm opacity-70 m-0 line-clamp-2">
                    {recipe.data.description}
                  </p>
                </div>

                <div class="mt-6 flex justify-between items-center font-mono text-sm border-t border-[var(--color-border-grid)] pt-3 border-opacity-50">
                  <div class="flex gap-4">
                    <span>P:{recipe.data.difficulty.prep}</span>
                    <span>T:{recipe.data.difficulty.technique}</span>
                    <span>N:{recipe.data.difficulty.cleanup}</span>
                  </div>
                  <span class="btn-execute">
                    EXÉCUTER_
                  </span>
                </div>
              </div>
            </a>
          );
        })
      }
    </div>
  </section>
</BaseLayout>

<script>
  const uptimeEl = document.getElementById("uptime-counter");
  if (uptimeEl) {
    let seconds = 0;
    setInterval(() => {
      seconds++;
      const h = String(Math.floor(seconds / 3600)).padStart(2, "0");
      const m = String(Math.floor((seconds % 3600) / 60)).padStart(2, "0");
      const s = String(seconds % 60).padStart(2, "0");
      uptimeEl.innerText = `${h}:${m}:${s}`;
    }, 1000);
  }
</script>
