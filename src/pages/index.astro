---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const recipes = await getCollection("recipes");
const ribeye = recipes.find((r) => r.id === "ribeye-steak");

const { Content } = ribeye ? await ribeye.render() : { Content: null };
---

<BaseLayout title="Kitchen OS | Main">
  <div class="mb-12 border-b border-[var(--color-border-grid)] pb-4">
    <h1 class="text-4xl text-[var(--color-accent)] mb-2 mt-0">/KITCHEN_OS</h1>
    <p class="font-mono text-sm opacity-80">
      System initialized. Awaiting culinary inputs...
    </p>
  </div>

  {
    ribeye && Content && (
      <article class="surface-card p-6 md:p-8">
        <header class="mb-8 border-b border-[var(--color-border-grid)] pb-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-[var(--color-accent)] text-white px-2 py-1 text-xs font-bold w-fit">
              PROTOCOL
            </span>
            <h2 class="text-3xl m-0">{ribeye.data.title}</h2>
          </div>
          <p class="font-mono text-sm opacity-80">{ribeye.data.description}</p>

          <div class="mt-6 font-mono text-sm flex gap-6">
            <div class="flex flex-col border border-[var(--color-border-grid)] p-3 items-center">
              <span class="text-[var(--color-accent)] font-bold mb-1 border-b border-[var(--color-border-grid)] pb-1 w-full text-center">
                SERVINGS
              </span>
              <span class="text-xl mt-1">{ribeye.data.baseServings}</span>
            </div>
          </div>
        </header>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="md:col-span-1">
            <div class="surface-card p-0 border-0 h-full">
              <h3 class="font-dot text-[var(--color-accent)] border-b border-[var(--color-border-grid)] pb-2 mb-4 mt-0 text-xl tracking-wider">
                INGREDIENTS
              </h3>
              <ul class="font-mono text-sm flex flex-col gap-3 p-0 m-0 list-none">
                {ribeye.data.ingredients.map((ing) => (
                  <li class="flex justify-between items-center border-b border-[var(--color-border-grid)] border-opacity-50 pb-2">
                    <span class="pr-2">{ing.name}</span>
                    <span class="font-bold text-right shrink-0">
                      {ing.quantity} {ing.unit}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="md:col-span-2 text-[#1A202C]">
            <h3 class="font-dot text-[var(--color-accent)] border-b border-[var(--color-border-grid)] pb-2 mb-4 mt-0 text-xl tracking-wider">
              EXECUTION PLAN
            </h3>
            <div class="recipe-content leading-relaxed">
              <Content />
            </div>
          </div>
        </div>
      </article>
    )
  }
</BaseLayout>

<style is:global>
  @reference "../styles/global.css";

  .recipe-content h1,
  .recipe-content h2,
  .recipe-content h3 {
    @apply font-dot text-[var(--color-accent)] mt-6 mb-3 uppercase text-2xl tracking-wide;
  }

  .recipe-content p {
    @apply mb-4 text-[#1A202C] opacity-90;
  }

  .recipe-content strong {
    @apply text-[var(--color-alert)];
  }
</style>
