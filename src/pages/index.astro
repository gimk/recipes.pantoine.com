---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const recipes = await getCollection("recipes");
---

<BaseLayout title="Kitchen OS | Main">
  <div class="mb-12 flex justify-between items-end">
    <div>
      <h1 class="text-4xl text-[var(--color-accent)] mb-2 mt-0 glow-accent flex items-center gap-1">
        /KITCHEN_OS<span class="cursor-blink"></span>
      </h1>
      <p class="font-mono text-sm opacity-80">
        Système initialisé. En attente d'instructions culinaires...
      </p>
    </div>
    <div class="hidden md:flex flex-col text-right font-mono text-xs opacity-70">
      <span>SYSTEM STATUS: <span class="text-[var(--color-accent)] glow-accent">SECURE</span></span>
      <span>UPTIME: <span id="uptime-counter">00:00:00</span></span>
    </div>
  </div>

  <section>
    <h2
      class="font-dot text-[var(--color-accent)] mb-6 mt-0 text-2xl tracking-wider glow-accent"
    >
      PROTOCOLES DISPONIBLES
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        recipes.map((recipe) => {
          const slug = recipe.id.replace(/\.mdx?$/, "");
          return (
            <a
              href={`/recipes/${slug}`}
              class="surface-card relative flex flex-col hover:border-[var(--color-accent)] transition-all duration-300 group cursor-pointer no-underline text-inherit block overflow-hidden hover:-translate-y-1 hover:shadow-[0_0_15px_rgba(0,209,255,0.15)] bg-[var(--color-surface)]"
              style="clip-path: polygon(0 0, 100% 0, 100% calc(100% - 15px), calc(100% - 15px) 100%, 0 100%);"
            >
              {/* Corner Stroke */}
              <svg class="absolute bottom-[-1px] right-[-1px] w-[16px] h-[16px] pointer-events-none z-20" viewBox="0 0 16 16">
                <line x1="16" y1="0" x2="0" y2="16" stroke="var(--color-border-grid)" stroke-width="1.5" class="group-hover:stroke-[var(--color-accent)] transition-colors duration-300" />
              </svg>
              
              {/* Decorative Brackets */}
              <div class="absolute top-2 left-2 w-2 h-2 border-t-2 border-l-2 border-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-opacity z-10 pointer-events-none"></div>
              <div class="absolute top-2 right-2 w-2 h-2 border-t-2 border-r-2 border-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-opacity z-10 pointer-events-none"></div>
              <div class="absolute bottom-2 left-2 w-2 h-2 border-b-2 border-l-2 border-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-opacity z-10 pointer-events-none"></div>
              {recipe.data.cover && (
                <div class="h-48 w-full border-b border-[var(--color-border-grid)] overflow-hidden">
                  <Image 
                    src={recipe.data.cover} 
                    alt={recipe.data.title} 
                    class="w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500" 
                  />
                </div>
              )}
              <div class="p-6 flex flex-col flex-grow justify-between">
                <div>
                  <div class="flex items-center justify-between mb-3">
                    <span class="bg-[var(--color-border-grid)] text-[var(--color-accent)] group-hover:bg-[var(--color-accent)] group-hover:text-white transition-colors px-2 py-1 text-xs font-bold font-mono border border-transparent group-hover:border-[var(--color-accent)]">
                      [{recipe.data.category.toUpperCase()}]
                    </span>
                    <span class="font-mono text-xs opacity-60 flex gap-3">
                      {recipe.data.kcal && <span>{recipe.data.kcal} KCAL</span>}
                      <span>{recipe.data.baseServings} PORTIONS</span>
                    </span>
                  </div>
                  <h3 class="text-xl m-0 mb-2 group-hover:text-[var(--color-accent)] transition-colors">
                    {recipe.data.title}
                  </h3>
                  <p class="font-mono text-sm opacity-70 m-0 line-clamp-2">
                    {recipe.data.description}
                  </p>
                </div>

                <div class="mt-6 flex justify-between items-center font-mono text-sm border-t border-[var(--color-border-grid)] pt-3 border-opacity-50">
                  <div class="flex gap-4">
                    <span>P:{recipe.data.difficulty.prep}</span>
                    <span>T:{recipe.data.difficulty.technique}</span>
                    <span>C:{recipe.data.difficulty.cleanup}</span>
                  </div>
                  <span class="text-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-x-4 group-hover:translate-x-0 whitespace-nowrap hidden sm:inline-block ml-2 font-bold tracking-widest glow-accent">
                    EXÉCUTER_
                  </span>
                </div>
              </div>
            </a>
          );
        })
      }
    </div>
  </section>
</BaseLayout>

<script>
  const uptimeEl = document.getElementById('uptime-counter');
  if (uptimeEl) {
    let seconds = 0;
    setInterval(() => {
      seconds++;
      const h = String(Math.floor(seconds / 3600)).padStart(2, '0');
      const m = String(Math.floor((seconds % 3600) / 60)).padStart(2, '0');
      const s = String(seconds % 60).padStart(2, '0');
      uptimeEl.innerText = `${h}:${m}:${s}`;
    }, 1000);
  }
</script>
