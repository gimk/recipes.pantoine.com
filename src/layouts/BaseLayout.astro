---
import "../styles/global.css";
const {
  title = "Antoine's Kitchen",
  description = "Recettes de cuisine",
  fullWidth = false,
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DotGothic16&family=Source+Code+Pro:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="kitchen-os bg-[#F8F9FA] text-[#1A202C] min-h-screen">
    <div class="scanline"></div>
    <div class={`p-6 md:p-12 ${fullWidth ? 'w-full max-w-[1600px] mx-auto' : 'max-w-5xl mx-auto'}`}>
      <slot />
    </div>
  </body>
</html>
